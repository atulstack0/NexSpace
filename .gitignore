# Dependencies
node_modules/
.pnp/
.pnp.js

# Builds / output
dist/
build/
.next/
.turbo/
out/

# Env & secrets (never commit) — .env.example IS committed
.env
.env.local
.env.*.local

# Prisma generated client (schema + migrations ARE committed)
**/node_modules/.prisma/

# SQLite dev database (created by `prisma migrate`; not committed)
*.db
*.db-journal
*.sqlite

# Persisted owner floor edits (written at runtime by the realtime server)
floors-data.json

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Editor / OS
.DS_Store
Thumbs.db
.vscode/
.idea/

# Test / coverage
coverage/

{
  "name": "nexspace",
  "version": "0.1.0",
  "private": true,
  "description": "NexSpace — spatial virtual office. Monorepo scaffold (Phase 0 + realtime position-sync slice).",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "start": "npm --workspace @nexspace/realtime start",
    "dev": "npm --workspace @nexspace/realtime run dev",
    "api": "npm --workspace @nexspace/api run dev",
    "api:setup": "npm --workspace @nexspace/api run prisma:generate && npm --workspace @nexspace/api run migrate && npm --workspace @nexspace/api run seed",
    "prisma:generate": "npm --workspace @nexspace/api run prisma:generate",
    "migrate": "npm --workspace @nexspace/api run migrate",
    "seed": "npm --workspace @nexspace/api run seed",
    "verify": "node scripts/verify.mjs",
    "test": "node scripts/realtime.smoke.mjs",
    "test:redis": "node scripts/redis.smoke.mjs",
    "test:api": "node scripts/api.smoke.mjs",
    "check": "npm run verify && npm test"
  },
  "devDependencies": {
    "ws": "^8.18.0"
  },
  "engines": {
    "node": ">=18"
  }
}

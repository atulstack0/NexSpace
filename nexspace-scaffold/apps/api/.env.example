# Copy to .env and adjust. Spin up Postgres quickly with:
#   docker run --name nexspace-pg -e POSTGRES_PASSWORD=nexspace -e POSTGRES_DB=nexspace -p 5432:5432 -d postgres:16
DATABASE_URL="postgresql://postgres:nexspace@localhost:5432/nexspace?schema=public"
PORT=3001

# LiveKit (optional). Without these, the client falls back to synth-tone audio.
# Local dev SFU:  livekit-server --dev   (prints url ws://localhost:7880, key devkey, secret secret)
# or use LiveKit Cloud and paste your project's values.
LIVEKIT_URL="ws://localhost:7880"
LIVEKIT_API_KEY="devkey"
LIVEKIT_API_SECRET="secret"

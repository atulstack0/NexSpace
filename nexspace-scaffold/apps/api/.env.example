# Copy to .env (Windows CMD: copy .env.example .env). Defaults need no edits.
#
# Database — SQLite by default (zero install, no Docker). `npm run migrate` creates the file.
DATABASE_URL="file:./dev.db"
PORT=3001

# Auth — must MATCH the realtime server's JWT_SECRET so it can verify login tokens.
# (Both default to the same dev value if unset.) Set a strong secret in production.
JWT_SECRET="nexspace-dev-secret-change-me"
# Demo logins: admin@nexspace.dev / admin1234   ·   member@nexspace.dev / member1234

# SSO / OIDC (optional). Without these, /auth/sso uses a built-in mock IdP (good for testing).
# OIDC_ISSUER="https://your-tenant.okta.com/oauth2/default"
# OIDC_CLIENT_ID="..."
# OIDC_CLIENT_SECRET="..."
# OIDC_REDIRECT_URI="http://localhost:3001/auth/sso/callback"
# OIDC_ADMIN_EMAILS="you@company.com"   # comma-separated → these SSO users get the admin role

# To use Postgres instead: set provider="postgresql" in prisma/schema.prisma, then:
# DATABASE_URL="postgresql://postgres:nexspace@localhost:5432/nexspace?schema=public"
# (docker-compose.yml in the scaffold root starts that Postgres.)

# LiveKit (optional — real voice/video). Without these, clients fall back to synth audio.
# Recommended on Windows (no Docker): a free project at https://cloud.livekit.io
# LIVEKIT_URL="wss://YOUR-PROJECT.livekit.cloud"
# LIVEKIT_API_KEY="API..."
# LIVEKIT_API_SECRET="..."
# Local dev SFU instead: livekit-server --dev  → ws://localhost:7880, key "devkey", secret "secret"

# Recording output (LiveKit Egress writes the .mp4 here). REQUIRED for actual file capture on
# LiveKit Cloud. Works with AWS S3, Cloudflare R2, or MinIO. Without it, the 🔴 indicator still
# shows for everyone but no file is written.
# S3_BUCKET="nexspace-recordings"
# S3_ACCESS_KEY="..."
# S3_SECRET="..."
# S3_REGION="auto"
# S3_ENDPOINT="https://<account>.r2.cloudflarestorage.com"

# Copy to .env (Windows CMD: copy .env.example .env). Defaults need no edits.
#
# Database — SQLite by default (zero install, no Docker). `npm run migrate` creates the file.
DATABASE_URL="file:./dev.db"
PORT=3001

# To use Postgres instead: set provider="postgresql" in prisma/schema.prisma, then:
# DATABASE_URL="postgresql://postgres:nexspace@localhost:5432/nexspace?schema=public"
# (docker-compose.yml in the scaffold root starts that Postgres.)

# LiveKit (optional — real voice/video). Without these, clients fall back to synth audio.
# Recommended on Windows (no Docker): a free project at https://cloud.livekit.io
# LIVEKIT_URL="wss://YOUR-PROJECT.livekit.cloud"
# LIVEKIT_API_KEY="API..."
# LIVEKIT_API_SECRET="..."
# Local dev SFU instead: livekit-server --dev  → ws://localhost:7880, key "devkey", secret "secret"

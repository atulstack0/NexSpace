// NexSpace persistence (spec §5). PostgreSQL via Prisma.
// Floors -> Rooms + PlacedObjects. The realtime server loads the world from here.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Floor {
  id          String          @id @default(cuid())
  slug        String          @unique          // e.g. "default" — how the realtime server requests it
  name        String
  width       Int
  height      Int
  environment String          @default("indoor") // 'indoor' | 'outdoor'
  supports3d  Boolean         @default(false)
  rooms       Room[]
  objects     PlacedObject[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model Room {
  id        String  @id @default(cuid())
  floor     Floor   @relation(fields: [floorId], references: [id], onDelete: Cascade)
  floorId   String
  key       String                              // stable id used on the wire, e.g. "focus"
  name      String
  color     String

  // bounds
  x         Int
  y         Int
  w         Int
  h         Int

  // door
  doorX     Int
  doorY     Int
  doorW     Int
  doorH     Int
  doorState String  @default("closed")          // 'open' | 'closed' | 'locked'
  audioMode String  @default("room")            // 'room' | 'broadcast'

  @@unique([floorId, key])
}

model PlacedObject {
  id         String  @id @default(cuid())
  floor      Floor   @relation(fields: [floorId], references: [id], onDelete: Cascade)
  floorId    String
  type       String                             // 'wall' | 'furniture' | 'mediaWall' | 'portal' | ...
  x          Float
  y          Float
  z          Float   @default(0)
  rotation   Float   @default(0)
  scale      Float   @default(1)
  collidable Boolean @default(true)
  config     Json    @default("{}")             // { w, h, r?, ...type-specific }
}
